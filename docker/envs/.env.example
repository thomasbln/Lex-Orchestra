# ─────────────────────────────────────────────────────────────
# Lex-Orchestra — Environment Reference
# Copy to docker/envs/.env and fill in your values.
# See docs/setup/docker.md for full documentation.
# ─────────────────────────────────────────────────────────────

# ── LLM Backend ──────────────────────────────────────────────
# Choose: api (external) or local (Ollama)
LLM_BACKEND=api

# If LLM_BACKEND=api — cloud LLM (optional, NON-default; the sovereign
# default is local Gemma via Ollama below). The working cloud backend in
# v1.0 is Anthropic; generic BYOK (any OpenAI-compatible endpoint) is
# planned but not wired yet.
# Examples:
ANTHROPIC_API_KEY=                # the working optional cloud backend (non-default)
LLM_MODEL=claude-sonnet-4-6

# If LLM_BACKEND=local — BYOM, any Ollama model
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_URL=http://ollama:11434/api/generate
OLLAMA_MODEL=gemma4:e4b

# ── Neo4j Backend ─────────────────────────────────────────────
# Choose: aura (cloud), local (container), custom (own instance)
NEO4J_BACKEND=aura
NEO4J_URI=neo4j+s://__SET_ME__.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
#
# For NEO4J_BACKEND=local (the sovereign profile — full set in .env.sovereign)
# the bundled Neo4j container needs the keys below. NEO4J_AUTH must match
# NEO4J_PASSWORD. In-network apps reach the DB at bolt://neo4j:7687; `make
# seed-all` runs on the host and uses bolt://localhost:7687 by default
# (override with NEO4J_LOCAL_URI). Uncomment and adjust:
#   NEO4J_BACKEND=local
#   NEO4J_URI=bolt://neo4j:7687
#   NEO4J_PASSWORD=__SET_ME__
#   NEO4J_AUTH=neo4j/__SET_ME__
#   NEO4J_PLUGINS=["apoc"]
#   NEO4J_server_memory_heap_initial__size=512m
#   NEO4J_server_memory_heap_max__size=1G
#   NEO4J_server_memory_pagecache_size=512m
#   NEO4J_server_config_strict__validation_enabled=false

# ── Supabase / PostgreSQL ─────────────────────────────────────
POSTGRES_PASSWORD=__SET_ME__
DATABASE_URL=postgresql://postgres:__SET_ME__@supabase-db:5432/postgres

# ── Network ───────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:3000
# CORS (F24): unset = approve_api allows every PRIVATE-network origin
# (RFC 1918 + localhost + *.local) — LAN-only by design; the API is
# unauthenticated (see Security posture in docs/setup/docker.md). Set an
# explicit comma-separated origin list ONLY when exposing beyond the LAN —
# and read the security notes first. NEVER expose ports 8001/3000 publicly.
# CORS_ORIGINS=http://localhost:3000

SCAN_WAIT_TIMEOUT=1800   # seconds approve_api waits for a scan (ADR-129 PR 7)
SCAN_REAPER_INTERVAL=600 # seconds between reaper sweeps for stuck 'running' scans

# ── Scan Status Updates (ADR-068) ─────────────────────────────
# The pipeline PATCHes live step updates to approve_api — same container,
# so localhost is correct (also the code default; cleanroom F21).
APPROVE_API_URL=http://localhost:8001
# Shared secret guarding PATCH /scan/{run_id}/step. Empty = guard disabled
# (trusted-LAN default). Recommended: openssl rand -hex 32
SCAN_INTERNAL_SECRET=
