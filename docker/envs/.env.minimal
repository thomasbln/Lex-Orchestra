# Lex-Orchestra — Minimal Profile
# No local containers for LLM or Neo4j.
# Runs on any machine with Docker.
# See docs/setup/quickstart.md

LLM_BACKEND=api
# Cloud LLM (optional, NON-default — the sovereign default is local Gemma via
# Ollama). The working cloud backend in v1.0 is Anthropic:
ANTHROPIC_API_KEY=your-api-key-here
LLM_MODEL=claude-sonnet-4-6

NEO4J_BACKEND=aura
NEO4J_URI=neo4j+s://__SET_ME__.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=__SET_ME__

POSTGRES_PASSWORD=__SET_ME__
DATABASE_URL=postgresql://postgres:__SET_ME__@supabase-db:5432/postgres

DASHBOARD_URL=http://localhost:3000

# Scan status updates (ADR-068): pipeline -> approve_api, same container (F21)
APPROVE_API_URL=http://localhost:8001
SCAN_INTERNAL_SECRET=    # empty = PATCH guard disabled; recommended: openssl rand -hex 32

# CORS (F24): unset = every private-network origin allowed (LAN-only by design).
# Set an explicit list only when exposing beyond the LAN — read the security notes.
# CORS_ORIGINS=http://localhost:3000

# Scan lifecycle knobs (ADR-129 PR 7 / ADR-068)
SCAN_WAIT_TIMEOUT=1800      # seconds approve_api waits for a scan run
SCAN_REAPER_INTERVAL=600    # seconds between reaper sweeps for stuck 'running' scans
